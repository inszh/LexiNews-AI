<view class="container">
  <scroll-view
    scroll-y
    class="feed-scroll"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
    bindscrolltolower="onScrollToLower"
    lower-threshold="100"
  >
    <!-- 分类筛选 -->
    <scroll-view scroll-x class="cat-scroll" show-scrollbar="{{false}}">
      <view class="cat-list">
        <view
          wx:for="{{categories}}"
          wx:key="index"
          class="cat-item {{selectedCategory === item ? 'cat-item-active' : ''}}"
          bindtap="selectCategory"
          data-cat="{{item}}"
        >{{item}}</view>
      </view>
    </scroll-view>

    <!-- 内容区域 -->
    <block wx:if="{{isLoading && leftColumn.length === 0}}">
      <view class="masonry-grid-skeleton">
        <view class="masonry-col-skeleton" wx:for="{{[1, 2]}}" wx:key="index">
          <view class="skeleton-card" wx:for="{{[1, 2, 3]}}" wx:key="index">
            <view class="skeleton-image-wrap skeleton-shimmer"></view>
            <view class="skeleton-content">
              <view class="skeleton-line-long skeleton-shimmer"></view>
              <view class="skeleton-line-short skeleton-shimmer"></view>
              <view class="skeleton-footer-mock">
                <view class="skeleton-circle skeleton-shimmer"></view>
                <view class="skeleton-line-footer skeleton-shimmer"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <!-- 瀑布流网格 -->
      <view class="masonry-grid" wx:if="{{allArticles.length > 0}}">
        <view class="masonry-col" wx:for="{{[leftColumn, rightColumn]}}" wx:for-item="column" wx:key="index">
          <view wx:for="{{column}}" wx:key="id" class="article-card" bindtap="openArticle" data-item="{{item}}">
            <view class="card-image-wrap" style="aspect-ratio: {{item.aspectRatio || 1.77}};">
              <!-- 图片加载前显示背景动画，分析 URL 中的尺寸信息预先撑开高度 -->
              <image
                wx:if="{{item.image}}"
                src="{{item.image}}"
                mode="aspectFill"
                class="main-image loaded skeleton-shimmer"
                lazy-load
                style="width: 100%; height: 100%;"
              ></image>
              <!-- 仅在彻底没图时展示一个基础占位块 -->
              <view wx:else class="image-placeholder-base skeleton-shimmer"></view>
            </view>

            <view class="card-body">
              <text class="card-title">{{item.title}}</text>
              <view class="card-footer">
                <view class="footer-left">
                  <image wx:if="{{item.icon}}" src="{{item.icon}}" class="source-icon" style="width: 28rpx; height: 28rpx; border-radius: 4rpx; margin-right: 8rpx;"></image>
                  <text class="source-name">{{item.sourceName}}</text>
                </view>
                <text class="footer-date">{{item.publishedAt}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 缺省提示 -->
      <view class="empty-state" wx:else>
        <view class="empty-icon-wrap">
          <text class="empty-icon">📂</text>
        </view>
        <text class="empty-title">LEXINEWS 提示</text>
        <text class="empty-desc">该分类下暂时没有新消息，您可以看看其他分类</text>
        <view class="empty-reset-btn" bindtap="resetCategory">回到全部</view>
      </view>
    </block>

    <!-- 加载更多 / 没有更多 -->
    <view class="load-more-row">
      <view wx:if="{{loadingMore}}" class="load-more-spinner">
        <view class="spinner-dot"></view>
        <view class="spinner-dot"></view>
        <view class="spinner-dot"></view>
      </view>
      <text wx:elif="{{noMore && allArticles.length > 0}}" class="no-more-text">— 已显示全部内容 —</text>
    </view>

    <view style="height: 50rpx;"></view>
  </scroll-view>
</view>