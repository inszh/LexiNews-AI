<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 使用页面原生滚动，解决 Canvas 随屏漂移问题 -->
  <view class="profile-content">
    <!-- 仪表盘直接顶格 -->
    <view class="dashboard-section section-gap" style="margin-top: 0 !important; padding-top: 32rpx !important;">
      <view class="section-label">
        <text class="section-label-icon">✦</text>
        <text class="section-label-text">学习成就</text>
      </view>

      <!-- 100% 全宽顶部：阅读 Streak -->
      <view class="dash-item-full">
        <view class="dash-card streak-card-full">
          <view class="streak-full-left">
            <view class="streak-fire-big {{isTodayRead ? 'fire-active' : ''}}">🔥</view>
          </view>
          <view class="streak-full-center">
            <view class="streak-num-wrap">
              <text class="streak-num-big">{{streak}}</text>
              <text class="streak-unit-big">天记录</text>
            </view>
            <text class="streak-title-dim">RESTREAK PRO</text>
          </view>
          <view class="streak-full-right">
            <view class="streak-status-badge {{isTodayRead ? 'status-active' : ''}}">
              {{isTodayRead ? '已达成' : '待阅读'}}
            </view>
          </view>
        </view>
      </view>

      <!-- 中间 1:1 双列：今日时长 & 累计文章 -->
      <view class="dashboard-stats-grid">
        <!-- 今日时长 -->
        <view class="dash-card stats-mini-card">
          <view class="mini-card-header">
            <text class="mini-card-title">今日时长</text>
          </view>
          <view class="mini-card-main">
            <text class="mini-card-val">{{todayMinutes}}</text>
            <text class="mini-card-unit">min</text>
            <view class="mini-progress-ring">
              <view class="mini-progress-fill" style="height: {{ (todayMinutes/60)*100 }}%"></view>
            </view>
          </view>
        </view>
        <!-- 累计阅读 -->
        <view class="dash-card stats-mini-card">
          <view class="mini-card-header">
            <text class="mini-card-title">本周阅读</text>
          </view>
          <view class="mini-card-main">
            <text class="mini-card-val">{{totalArticles}}</text>
            <text class="mini-card-unit">篇</text>
            <view class="mini-icon-box">📚</view>
          </view>
        </view>
      </view>

      <!-- 本周阅读活跃 (置于词汇上方) -->
      <view class="dash-card activity-card shadow-sm">
        <view class="dash-card-header">
          <view class="header-main">
            <text class="dash-card-title">本周活跃</text>
            <text class="dash-card-subtitle">Reading Consistency</text>
          </view>
          <view class="activity-avg">
            <text class="avg-val">{{todayMinutes}}<text class="avg-unit">min</text></text>
            <text class="avg-lbl">今日阅读</text>
          </view>
        </view>
        <view class="bar-chart-modern">
          <view class="bar-item-modern" wx:for="{{weeklyStats}}" wx:key="label">
            <view class="bar-col-wrap-modern">
              <view class="bar-col-modern {{item.minutes > 0 ? 'active' : ''}}" style="height: {{item.height || 0}}%"></view>
            </view>
            <text class="bar-label-modern">{{item.label}}</text>
          </view>
          <view class="chart-guide-line"></view>
        </view>
      </view>

      <!-- 词汇成长曲线 -->
      <view class="dash-card vocab-card shadow-sm">
        <view class="dash-card-header">
          <view>
            <text class="dash-card-title">词汇成长</text>
          </view>
          <view class="vocab-total">
            <text class="vocab-total-num">{{wordTotal || 0}}</text>
            <text class="vocab-total-lbl">累计</text>
          </view>
        </view>

        <!-- 生词卡片列表 (前置展示) -->
        <view class="recent-words-wrap" wx:if="{{recentWords && recentWords.length > 0}}">
          <scroll-view 
            scroll-x 
            class="recent-words-scroll" 
            enhanced 
            show-scrollbar="{{false}}"
            bindscrolltolower="fetchMoreVocab"
            lower-threshold="100"
          >
            <view class="recent-words-list">
              <view 
                class="word-chip {{item.showTrans ? 'chip-trans' : ''}}" 
                wx:for="{{recentWords}}" 
                wx:key="index"
                bindtap="toggleWordTrans"
                data-index="{{index}}"
                style="animation-delay: {{index * 0.08}}s"
              >
                {{item.showTrans ? (item.trans_general || item.trans || '无翻译') : item.word}}
              </view>
              <!-- 加载中占位 -->
              <view class="word-chip" style="opacity: 0.5; font-weight: normal;" wx:if="{{isVocabLoading}}">加载中...</view>
            </view>
          </scroll-view>
        </view>
        <view class="recent-words-empty" wx:else>尚未记录生词</view>

        <!-- 曲线图移至下方 -->
        <view class="chart-container" wx:if="{{wordGrowth && wordGrowth.length > 1}}">
          <canvas type="2d" id="vocabChart" class="vocab-canvas"></canvas>
        </view>
      </view>

    </view>

    <!-- 社交推广区 -->
    <view class="section-gap">
      <view class="section-label">
        <text class="section-label-icon">✦</text>
        <text class="section-label-text">关注作者</text>
      </view>
      <view class="social-cards">

        <!-- 小红书 -->
        <view class="social-card xhs-card" bindtap="openXiaohongshu">
          <view class="social-card-left">
            <view class="social-info">
              <text class="social-name">@Zane同学</text>
              <text class="social-desc">小红书 · 干货笔记分享</text>
            </view>
          </view>
          <view class="social-follow-btn xhs-btn">
            <text class="social-follow-text">关注</text>
          </view>
        </view>

        <!-- 微信公众号 -->
        <view class="social-card wechat-card" bindtap="openWechatOA">
          <view class="social-card-left">
            <view class="social-info">
              <text class="social-name">@Zane同学说</text>
              <text class="social-desc">微信公众号 · 深度内容</text>
            </view>
          </view>
          <view class="social-follow-btn wechat-btn">
            <text class="social-follow-text">订阅</text>
          </view>
        </view>

      </view>
    </view>

    <!-- AI 配置 (v2.0 集中化管理版) -->
    <view class="section-gap">
      <view class="section-label">
        <text class="section-label-icon">✦</text>
        <text class="section-label-text">AI 服务状态</text>
      </view>

      <view class="cfg-field-card">
        <view class="cfg-field-top">
          <view class="cfg-field-meta" style="flex:1">
            <text class="cfg-field-title">当前模型: {{serverAiConfig.model || '加载中...'}}</text>
            <text class="cfg-field-desc">由 LexiNews AI 服务端统一驱动</text>
          </view>
          <view class="status-badge {{serverAiConfig.status==='Active' ? 'active' : ''}}">
            {{serverAiConfig.status || 'Offline'}}
          </view>
        </view>
        
        <view class="cfg-input-box-alt">
          <view class="config-info-row">
            <text class="info-label">语音解析 (TTS)</text>
            <text class="info-val">{{serverAiConfig.enable_tts ? '已开启' : '未开启'}}</text>
          </view>
          <view class="config-info-row">
            <text class="info-label">最后同步</text>
            <text class="info-val">{{serverAiConfig.last_updated || '刚刚'}}</text>
          </view>
        </view>
      </view>

      <view class="cfg-security-note" style="margin-top:24rpx">
        <text class="cfg-security-text">系统已启用 Notion AI 配置同步。管理员可通过 Notion 实时调整模型参数，前端不再存储 Key，保障账户安全。</text>
      </view>
    </view>


    <!-- 缓存管理 -->
    <view class="section-gap">
      <view class="section-label">
        <text class="section-label-text">存储与缓存</text>
      </view>
      <view class="about-card">
        <view class="about-row">
          <text class="about-lbl">当前占用</text>
          <text class="about-val">{{cacheSize}}</text>
        </view>
        <view class="about-row with-border">
          <text class="about-lbl">已缓存文章</text>
          <text class="about-val">{{cacheCount}} 篇</text>
        </view>
        <view class="cache-clear-row">
          <button class="cache-clear-btn" bindtap="clearCache">清理全部缓存</button>
        </view>
      </view>
    </view>

    <!-- 关于 -->
    <view class="section-gap">
      <view class="section-label">
        <text class="section-label-icon">✦</text>
        <text class="section-label-text">关于</text>
      </view>
      <view class="about-card">
        <view class="about-row">
          <text class="about-lbl">版本</text>
          <text class="about-val">1.0</text>
        </view>
      </view>
    </view>


    <view style="height:120rpx"></view>
  </view>
</view>
