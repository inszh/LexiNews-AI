/* pages/profile/profile.wxss */

/* ===== 基础 ===== */
.container {
  min-height: 100vh;
  background: #F4F2EF;
}

/* ===== Hero 区 ===== */
.hero-section {
  position: relative;
  background: #1A1A18;
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  border-radius: 0 0 48rpx 48rpx;
}

.hero-blur-bg {
  position: absolute;
  top: -80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255,220,80,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 28rpx;
}

.avatar-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 3rpx solid rgba(255,255,255,0.2);
  padding: 6rpx;
  background: rgba(255,255,255,0.05);
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #F0B429;
  color: #1A1A18;
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  border: 3rpx solid #1A1A18;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  text-align: center;
  margin-bottom: 10rpx;
}

.profile-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  text-align: center;
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.08);
  border-radius: 28rpx;
  padding: 28rpx 0;
  width: 100%;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.12);
}

.stat-emoji {
  font-size: 32rpx;
  display: block;
}

.stat-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  line-height: 1;
}

.stat-lbl {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  font-weight: 500;
  display: block;
}

/* ===== 通用分区块 ===== */
.section-gap {
  margin: 60rpx 32rpx 0;
}

.section-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.section-label-icon {
  font-size: 22rpx;
  color: #8A8680;
}

.section-label-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A18;
  letter-spacing: 1rpx;
}

/* ===== 社交推广卡片 ===== */
.social-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.social-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.social-card:active {
  opacity: 0.85;
  transform: scale(0.99);
}

.social-card-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.social-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.xhs-icon-bg {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
}

.wechat-icon-bg {
  background: linear-gradient(135deg, #07C160, #24AE5F);
}

.social-icon {
  font-size: 44rpx;
  line-height: 1;
}

.social-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.social-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A18;
  display: block;
}

.social-desc {
  font-size: 22rpx;
  color: #8A8680;
  display: block;
}

.social-follow-btn {
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.xhs-btn {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
}

.wechat-btn {
  background: linear-gradient(135deg, #07C160, #24AE5F);
}

.social-follow-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ===== AI 配置 — 新版卡片式字段 ===== */

/* 每个字段独立白卡 */
.cfg-field-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 0;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

/* 顶部：图标 + 标题 + 描述 */
.cfg-field-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

/* 彩色图标 badge */
.cfg-icon-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.url-badge   { background: linear-gradient(135deg, #4F8EF7, #6DB8FF); }
.key-badge   { background: linear-gradient(135deg, #F0B429, #FFD166); }
.model-badge { background: linear-gradient(135deg, #7C3AED, #A78BFA); }

.cfg-badge-icon {
  font-size: 36rpx;
  line-height: 1;
}

/* 标题 + 副标题 */
.cfg-field-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cfg-field-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A18;
  display: block;
}

.cfg-field-desc {
  font-size: 22rpx;
  color: #A8A4A0;
  display: block;
}

/* 眼睛按钮 */
.cfg-eye-btn {
  width: 60rpx;
  height: 60rpx;
  background: #F4F2EF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cfg-eye-icon { font-size: 30rpx; line-height: 1; }

/* 输入框容器 — 带左侧彩色竖线 */
.cfg-input-box {
  border-top: 1rpx solid rgba(26,26,24,0.06);
  margin: 0 -28rpx;          /* 撑满卡片宽度 */
  padding: 0 28rpx;
  background: #FAFAF8;
  border-radius: 0 0 24rpx 24rpx;
  border-left: 6rpx solid transparent;
  transition: border-color 0.2s;
  position: relative;
}

/* input 本体 */
.cfg-inp {
  width: 100%;
  height: 88rpx;
  font-size: 26rpx;
  color: #1A1A18;
  letter-spacing: 0.3px;
  background: transparent;
}

/* API Key 等宽字体感 */
.cfg-inp-mono {
  font-size: 24rpx;
  letter-spacing: 1px;
}

/* 按钮组 */
.cfg-btn-group {
  display: flex;
  gap: 16rpx;
}

.cfg-btn-reset {
  flex: 1;
  background: #EEEBE6;
  color: #6A6660;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  padding: 24rpx 0;
  line-height: 1;
}
.cfg-btn-reset::after { border: none; }

.cfg-btn-save {
  flex: 2;
  background: #1A1A18;
  color: #FAFAF7;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  padding: 24rpx 0;
  line-height: 1;
}
.cfg-btn-save::after { border: none; }

/* 安全提示 */
.cfg-security-note {
  background: #F4F2EF;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.cfg-security-text {
  font-size: 22rpx;
  color: #A8A4A0;
  flex: 1;
  line-height: 1.5;
}

/* ===== 关于卡片 ===== */
.about-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.about-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 0;
}

.with-border {
  border-top: 1rpx solid rgba(26,26,24,0.06);
}

.about-lbl {
  font-size: 28rpx;
  color: #6A6660;
  font-weight: 500;
}

.about-val {
  font-size: 28rpx;
  color: #1A1A18;
  font-weight: 700;
}

/* 缓存策略文字 */
.cache-tip {
  font-size: 22rpx;
  color: #A8A4A0;
  font-weight: 500;
}

/* 清除缓存按钮行 */
.cache-clear-row {
  padding: 20rpx 0 12rpx;
  border-top: 1rpx solid rgba(26,26,24,0.06);
  margin-top: 4rpx;
}

.cache-clear-btn {
  width: 100%;
  background: rgba(255, 59, 48, 0.08);
  color: #FF3B30;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  padding: 22rpx 0;
  line-height: 1;
}
.cache-clear-btn::after { border: none; }

/* ===== 学习仪表盘 - 增强设计 ===== */
.dashboard-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.dash-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 18rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  position: relative;
  overflow: hidden;
}

.shadow-sm {
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.streak-card {
  flex: 3;
  background: linear-gradient(135deg, #1A1A18 0%, #333330 100%);
  color: #FFF;
}

.time-card {
  flex: 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dash-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.dash-card-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #8A8680;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.streak-card .dash-card-title {
  color: rgba(255,255,255,0.5);
}

.dash-card-subtitle {
  font-size: 20rpx;
  color: #C8C4BF;
  font-weight: 600;
}

.streak-status {
  font-size: 18rpx;
  background: rgba(255,255,255,0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  color: rgba(255,255,255,0.5);
}

.streak-status.status-active {
  background: #24AE5F;
  color: #FFF;
}

.streak-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 16rpx 0;
}

.streak-fire {
  font-size: 56rpx;
  filter: grayscale(1);
  opacity: 0.3;
  transition: all 0.3s;
}

.fire-active {
  filter: grayscale(0);
  opacity: 1;
  transform: scale(1.1);
  text-shadow: 0 0 20rpx rgba(255,80,0,0.4);
}

.streak-info {
  display: flex;
  flex-direction: column;
}

.streak-num {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
}

.streak-unit {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.4);
  margin-top: 4rpx;
}

.streak-tip {
  font-size: 20rpx;
  color: #F0B429;
  margin-top: 10rpx;
  display: block;
}

.time-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.time-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #1A1A18;
}

.time-circle {
  width: 40rpx;
  height: 80rpx;
  background: #F4F2EF;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.time-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #24AE5F;
  border-radius: 20rpx;
  transition: height 0.6s ease-out;
}

/* 词汇曲线 */
.vocab-card {
  margin-bottom: 20rpx;
}

.vocab-total {
  background: #F4F2EF;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.vocab-total-num {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A1A18;
}

.vocab-total-lbl {
  font-size: 18rpx;
  color: #8A8680;
  font-weight: 700;
  text-transform: uppercase;
}

.chart-container {
  height: 160rpx;
  width: 100%;
  margin-top: 12rpx;
  background: #FAFAF8;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  position: relative;
}

.vocab-canvas {
  width: 100%;
  height: 100%;
  display: block;
  overflow: hidden;
  pointer-events: none;
}

/* 里程碑 */
.milestone-card {
  margin-bottom: 20rpx;
}

.milestone-remind {
  font-size: 20rpx;
  color: #F0B429;
}

.milestone-progress-wrap {
  margin-top: 40rpx;
  padding: 0 20rpx 20rpx;
  position: relative;
}

.milestone-bar-bg {
  height: 8rpx;
  background: #F4F2EF;
  border-radius: 4rpx;
  position: relative;
}

.milestone-bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: #F0B429;
  border-radius: 4rpx;
  transition: width 0.8s ease-in-out;
}

.milestone-nodes {
  position: absolute;
  top: -6rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}

.milestone-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.node-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #FFF;
  border: 4rpx solid #F4F2EF;
  z-index: 2;
  transition: all 0.3s;
}

.node-done .node-dot {
  background: #F0B429;
  border-color: #FFF;
  box-shadow: 0 0 12rpx rgba(240,180,41,0.4);
}

.node-lbl {
  font-size: 18rpx;
  font-weight: 700;
  color: #C8C4BF;
}

.node-done .node-lbl {
  color: #1A1A18;
}

/* 本周活跃柱状图 */
.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 120rpx;
  padding: 0 10rpx;
  margin-top: 20rpx;
}

.bar-item {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.bar-col-wrap {
  flex: 1;
  width: 12rpx;
  background: #F4F2EF;
  border-radius: 6rpx;
  position: relative;
  overflow: hidden;
  height: 100rpx;
}

.bar-col {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: #1A1A18;
  border-radius: 6rpx;
  transition: height 0.6s ease-out;
}

.bar-label {
  font-size: 18rpx;
  color: #8A8680;
  font-weight: 600;
}

/* ===== 里程碑 - 发现页样式移植 ===== */
.milestone-card-disc {
  margin-bottom: 20rpx;
}

.milestone-box-disc {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.milestone-current-disc {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  min-width: 120rpx;
}

.ms-val-disc {
  font-size: 56rpx;
  font-weight: 800;
  color: #1a1a18;
  line-height: 1;
}

.ms-lbl-disc {
  font-size: 20rpx;
  color: #8A8680;
  margin-top: 8rpx;
  font-weight: 600;
}

.milestone-progress-wrap-disc {
  flex: 1;
}

.ms-progress-bar-disc {
  width: 100%;
  height: 12rpx;
  background: #F4F2EF;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.ms-progress-inner-disc {
  height: 100%;
  background: linear-gradient(90deg, #F0B429, #FFD700);
  border-radius: 6rpx;
  transition: width 1s ease-out;
}

.ms-note-disc {
  font-size: 20rpx;
  color: #C8C4BF;
  font-weight: 600;
}

.milestone-badges-disc {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.ms-badge-disc {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #F4F2EF;
  color: #C8C4BF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  border: 4rpx solid #FFF;
  transition: all 0.3s;
}

.ms-badge-disc.badge-active {
  background: #FFF;
  color: #F0B429;
  border: 4rpx solid #F0B429;
  box-shadow: 0 4rpx 12rpx rgba(240,180,41,0.2);
}

/* ===== 单词浮动动画 ===== */
.floating-words-wrap {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
}

.floating-word {
  position: absolute;
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(240, 180, 41, 0.4);
  background: rgba(240, 180, 41, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  animation: floatAround 8s infinite ease-in-out;
  border: 1rpx solid rgba(240, 180, 41, 0.1);
}

@keyframes floatAround {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 0; }
  20% { opacity: 0.8; }
  50% { transform: translate(20rpx, -40rpx) rotate(5deg); opacity: 0.5; }
  80% { opacity: 0.8; }
  100% { transform: translate(-10rpx, -80rpx) rotate(-5deg); opacity: 0; }
}

/* 确保 canvas 置于上层或下层根据设计 */
.vocab-canvas {
  position: relative;
  z-index: 2;
}

/* ===== 最近生词列表样式 ===== */
.recent-words-wrap {
  margin: 24rpx 0 0;
  width: 100%;
  height: 330rpx; /* 强制 4 行的高度 */
}

.recent-words-scroll {
  width: 100%;
  height: 100%;
}

.recent-words-list {
  display: flex;
  flex-direction: column;
  flex-wrap: wrap;
  align-items: flex-start; /* 关键：让每个单词根据自身长度自适应宽度，不拉伸 */
  gap: 16rpx 20rpx;
  padding: 4rpx 0 20rpx;
  height: 100%; /* 继承 wrap 的 330rpx */
  width: max-content;
}

.chip-trans {
  background: #1A1A18 !important;
  color: #FFFFFF !important;
  border-color: #1A1A18 !important;
}

.word-chip {
  background: #FFFFFF;
  color: #1A1A18;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid #F0EDE8;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: chipBounceIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
}

.word-chip:active {
  transform: scale(0.95);
  background: #F0B429;
  color: #FFFFFF;
  border-color: #F0B429;
}

.recent-words-empty {
  font-size: 24rpx;
  color: #C8C4BF;
  text-align: center;
  padding: 40rpx 0;
}

/* ===== 炫酷单词动画 (保持现有) ===== */
@keyframes chipBounceIn {
  0% { opacity: 0; transform: translateY(30rpx) scale(0.5); }
  70% { opacity: 1; transform: translateY(-5rpx) scale(1.05); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.word-chip:nth-child(odd) {
  animation: chipBounceIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards, 
             chipFloat 3s ease-in-out infinite 0.6s;
}

.word-chip:nth-child(even) {
  animation: chipBounceIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards, 
             chipFloat 3.5s ease-in-out infinite 0.8s;
}

@keyframes chipFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

