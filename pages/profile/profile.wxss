/* pages/profile/profile.wxss */

/* ===== 基础 ===== */
.container {
  min-height: 100vh;
  background: #F4F2EF;
}

/* ===== Hero 区 ===== */
.hero-section {
  position: relative;
  background: #1A1A18;
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  border-radius: 0 0 48rpx 48rpx;
}

.hero-blur-bg {
  position: absolute;
  top: -80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255,220,80,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 28rpx;
}

.avatar-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 3rpx solid rgba(255,255,255,0.2);
  padding: 6rpx;
  background: rgba(255,255,255,0.05);
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #F0B429;
  color: #1A1A18;
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  border: 3rpx solid #1A1A18;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  text-align: center;
  margin-bottom: 10rpx;
}

.profile-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  text-align: center;
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.08);
  border-radius: 28rpx;
  padding: 28rpx 0;
  width: 100%;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.12);
}

.stat-emoji {
  font-size: 32rpx;
  display: block;
}

.stat-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  line-height: 1;
}

.stat-lbl {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  font-weight: 500;
  display: block;
}

/* ===== 通用分区块 ===== */
.section-gap {
  margin: 32rpx 24rpx 0;
}

.section-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.section-label-icon {
  font-size: 22rpx;
  color: #8A8680;
}

.section-label-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A18;
  letter-spacing: 1rpx;
}

/* ===== 社交推广卡片 ===== */
.social-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.social-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.social-card:active {
  opacity: 0.85;
  transform: scale(0.99);
}

.social-card-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.social-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.xhs-icon-bg {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
}

.wechat-icon-bg {
  background: linear-gradient(135deg, #07C160, #24AE5F);
}

.social-icon {
  font-size: 44rpx;
  line-height: 1;
}

.social-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.social-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A18;
  display: block;
}

.social-desc {
  font-size: 22rpx;
  color: #8A8680;
  display: block;
}

.social-follow-btn {
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.xhs-btn {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
}

.wechat-btn {
  background: linear-gradient(135deg, #07C160, #24AE5F);
}

.social-follow-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ===== AI 配置 — 新版卡片式字段 ===== */

/* 每个字段独立白卡 */
.cfg-field-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 0;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

/* 顶部：图标 + 标题 + 描述 */
.cfg-field-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

/* 彩色图标 badge */
.cfg-icon-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.url-badge   { background: linear-gradient(135deg, #4F8EF7, #6DB8FF); }
.key-badge   { background: linear-gradient(135deg, #F0B429, #FFD166); }
.model-badge { background: linear-gradient(135deg, #7C3AED, #A78BFA); }

.cfg-badge-icon {
  font-size: 36rpx;
  line-height: 1;
}

/* 标题 + 副标题 */
.cfg-field-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cfg-field-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A18;
  display: block;
}

.cfg-field-desc {
  font-size: 22rpx;
  color: #A8A4A0;
  display: block;
}

/* 眼睛按钮 */
.cfg-eye-btn {
  width: 60rpx;
  height: 60rpx;
  background: #F4F2EF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cfg-eye-icon { font-size: 30rpx; line-height: 1; }

/* 输入框容器 — 带左侧彩色竖线 */
.cfg-input-box {
  border-top: 1rpx solid rgba(26,26,24,0.06);
  margin: 0 -28rpx;          /* 撑满卡片宽度 */
  padding: 0 28rpx;
  background: #FAFAF8;
  border-radius: 0 0 24rpx 24rpx;
  border-left: 6rpx solid transparent;
  transition: border-color 0.2s;
  position: relative;
}

/* input 本体 */
.cfg-inp {
  width: 100%;
  height: 88rpx;
  font-size: 26rpx;
  color: #1A1A18;
  letter-spacing: 0.3px;
  background: transparent;
}

/* API Key 等宽字体感 */
.cfg-inp-mono {
  font-size: 24rpx;
  letter-spacing: 1px;
}

/* 按钮组 */
.cfg-btn-group {
  display: flex;
  gap: 16rpx;
}

.cfg-btn-reset {
  flex: 1;
  background: #EEEBE6;
  color: #6A6660;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  padding: 24rpx 0;
  line-height: 1;
}
.cfg-btn-reset::after { border: none; }

.cfg-btn-save {
  flex: 2;
  background: #1A1A18;
  color: #FAFAF7;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  padding: 24rpx 0;
  line-height: 1;
}
.cfg-btn-save::after { border: none; }

/* 安全提示 */
.cfg-security-note {
  background: #F4F2EF;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.cfg-security-text {
  font-size: 22rpx;
  color: #A8A4A0;
  flex: 1;
  line-height: 1.5;
}

/* ===== 关于卡片 ===== */
.about-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.about-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 0;
}

.with-border {
  border-top: 1rpx solid rgba(26,26,24,0.06);
}

.about-lbl {
  font-size: 28rpx;
  color: #6A6660;
  font-weight: 500;
}

.about-val {
  font-size: 28rpx;
  color: #1A1A18;
  font-weight: 700;
}

/* 缓存策略文字 */
.cache-tip {
  font-size: 22rpx;
  color: #A8A4A0;
  font-weight: 500;
}

/* 清除缓存按钮行 */
.cache-clear-row {
  padding: 20rpx 0 12rpx;
  border-top: 1rpx solid rgba(26,26,24,0.06);
  margin-top: 4rpx;
}

.cache-clear-btn {
  width: 100%;
  background: rgba(255, 59, 48, 0.08);
  color: #FF3B30;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  padding: 22rpx 0;
  line-height: 1;
}
.cache-clear-btn::after { border: none; }
