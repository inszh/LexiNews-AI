<page-meta page-style="{{ showAiPanel ? 'overflow: hidden;' : '' }}" />
<view class="container">
  <scroll-view
    scroll-y="{{!showAiPanel}}"
    class="detail-scroll"
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="{{scrollTarget}}"
    scroll-top="{{savedScrollTop}}"
    scroll-with-animation
    bindscroll="onPageScrollLocal"
  >

    <view class="article-body">
      <view 
        class="article-title-wrap" 
        bindtouchstart="onParagraphTouchStart"
        bindtouchend="onParagraphTouchEnd"
        bindtouchmove="onParagraphTouchMove"
        data-index="-1" 
        data-text="{{article.title}}"
      >
        <block wx:if="{{article.titleWords}}">
          <block wx:for="{{article.titleWords}}" wx:for-item="w" wx:key="id">
            <text 
              wx:if="{{w.isWord}}"
              id="{{w.id}}"
              class="article-title word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}"
              bindtap="onWordTap"
              data-word="{{w.text}}"
              data-sentence="{{article.title}}"
              data-id="{{w.id}}"
            >{{w.text}}</text>
            <text wx:else class="article-title word-text">{{w.text}}</text>
          </block>
        </block>
        <text wx:else class="article-title">{{article.title}}</text>
      </view>
      
      <view class="meta-row">
        <image wx:if="{{article.icon}}" src="{{article.icon}}" class="author-avatar"></image>
        <view class="meta-info">
          <text class="author-name">{{article.sourceName || 'Reuters'}}</text>
        </view>
        <text class="meta-readtime">阅读时长：{{article.readTime || 1}} 分钟</text>
      </view>

      <view class="summary-box" wx:if="{{article.summary}}"
        bindtouchstart="onParagraphTouchStart"
        bindtouchend="onParagraphTouchEnd"
        bindtouchmove="onParagraphTouchMove"
        data-index="-2"
        data-text="{{article.summary}}"
      >
        <text class="summary-label">摘要</text>
        <text class="summary-text">{{article.summary}}</text>
      </view>

      <!-- 文章全文的 AI 分析结果 -->
      <view id="blk--3">
        <block wx:if="{{article.fullInserts && article.fullInserts.length > 0}}">
          <view wx:for="{{article.fullInserts}}" wx:for-item="ins" wx:for-index="insIdx" wx:key="id" class="ai-insert-card ai-full-analysis-card" style="margin: 0 32rpx 20rpx;">
            <view class="ai-insert-header">
              <view class="ai-insert-header-left">
                <text class="ai-insert-icon">✦</text>
                <text class="ai-insert-prompt">全文：{{ins.prompt}}</text>
              </view>
              <view class="ai-insert-close" bindtap="onRemoveAnalysis" data-index="-3" data-id="{{ins.id}}">×</view>
            </view>
            <text class="ai-insert-result" user-select>{{ins.result}}</text>
          </view>
        </block>
      </view>

      <!-- 文章摘要的 AI 分析结果 -->
      <view id="blk--2">
        <block wx:if="{{article.summaryInserts && article.summaryInserts.length > 0}}">
          <view wx:for="{{article.summaryInserts}}" wx:for-item="ins" wx:for-index="insIdx" wx:key="id" class="ai-insert-card" style="margin: 0 32rpx 20rpx;">
            <view class="ai-insert-header">
              <view class="ai-insert-header-left">
                <text class="ai-insert-icon">✦</text>
                <text class="ai-insert-prompt">{{ins.prompt}}</text>
              </view>
              <view class="ai-insert-close" bindtap="onRemoveAnalysis" data-index="-2" data-id="{{ins.id}}">×</view>
            </view>
            <text class="ai-insert-result" user-select>{{ins.result}}</text>
          </view>
        </block>
      </view>

      <!-- 文章标题的 AI 分析结果 -->
      <view id="blk--1">
        <block wx:if="{{article.inserts && article.inserts.length > 0}}">
          <view wx:for="{{article.inserts}}" wx:for-item="ins" wx:for-index="insIdx" wx:key="id" class="ai-insert-card" style="margin: 0 32rpx 20rpx;">
            <view class="ai-insert-header">
              <view class="ai-insert-header-left">
                <text class="ai-insert-icon">✦</text>
                <text class="ai-insert-prompt">{{ins.prompt}}</text>
              </view>
              <view class="ai-insert-close" bindtap="onRemoveAnalysis" data-index="-1" data-id="{{ins.id}}">×</view>
            </view>
            <text class="ai-insert-result" user-select>{{ins.result}}</text>
          </view>
        </block>
      </view>

      <view class="content-area">
        <!-- AI 提示横幅 -->
        <view class="ai-hint-bar">
          <text class="ai-hint-icon">✦</text>
          <text class="ai-hint-text">长按文字段落，可选中后进行 AI 分析</text>
        </view>

        <!-- 骨架屏：加载中显示闪动灰色块 -->
        <view wx:if="{{isLoading && (!paragraphs || paragraphs.length === 0)}}" class="skeleton-wrap">
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-3q"></view>
          <view class="skeleton-gap"></view>
          <view class="skeleton-image"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-half"></view>
          <view class="skeleton-gap"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-3q"></view>
          <view class="skeleton-gap"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-full"></view>
          <view class="skeleton-line skeleton-line-half"></view>
        </view>

        <!-- 用 view 包裹每个 block，便于 scroll-into-view 定位 -->
        <block wx:for="{{paragraphs}}" wx:key="index">
          <view id="blk-{{index}}">

            <!-- 段落 -->
            <view
              wx:if="{{item.type === 'p'}}"
              class="paragraph {{selectedIndex === index ? 'paragraph-selected' : ''}}"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}"
              data-text="{{item.text}}"
            >
              <block wx:if="{{item.words}}">
                <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text 
                    wx:if="{{w.isWord}}"
                    id="{{w.id}}"
                    class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}"
                    bindtap="onWordTap"
                    data-word="{{w.text}}"
                    data-sentence="{{item.text}}"
                    data-id="{{w.id}}"
                  >{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
              </block>
              <text wx:else>{{item.text}}</text>
            </view>

            <!-- 标题和其他内容块（同样支持长按分析） -->
            <view wx:if="{{item.type === 'h1'}}" class="block-h1"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
               <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
            </view>
            <view wx:if="{{item.type === 'h2'}}" class="block-h2"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
               <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
            </view>
            <view wx:if="{{item.type === 'h3'}}" class="block-h3"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
               <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
            </view>
            <view wx:if="{{item.type === 'bullet'}}" class="block-bullet"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
              <text class="bullet-dot">•</text>
              <view class="bullet-text">
                <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
              </view>
            </view>
            <view wx:if="{{item.type === 'numbered'}}" class="block-bullet"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
              <text class="bullet-dot">—</text>
              <view class="bullet-text">
                <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
              </view>
            </view>
            <view wx:if="{{item.type === 'quote'}}" class="block-quote"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
               <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
            </view>
            <view wx:if="{{item.type === 'callout'}}" class="block-callout"
              bindtouchstart="onParagraphTouchStart"
              bindtouchend="onParagraphTouchEnd"
              bindtouchmove="onParagraphTouchMove"
              data-index="{{index}}" data-text="{{item.text}}">
              <text class="callout-emoji">{{item.emoji}}</text>
              <view class="callout-text">
                <block wx:for="{{item.words}}" wx:for-item="w" wx:key="id">
                  <text wx:if="{{w.isWord}}" id="{{w.id}}" class="word-item {{highlightWordId === w.id ? 'word-highlight' : ''}}" bindtap="onWordTap" data-word="{{w.text}}" data-sentence="{{item.text}}" data-id="{{w.id}}">{{w.text}}</text>
                  <text wx:else class="word-text">{{w.text}}</text>
                </block>
              </view>
            </view>

            <!-- AI 分析结果卡片（任意块类型均支持） -->
            <block wx:if="{{item.inserts && item.inserts.length > 0}}">
              <view
                wx:for="{{item.inserts}}"
                wx:for-item="ins"
                wx:for-index="insIdx"
                wx:key="id"
                class="ai-insert-card"
              >
                <view class="ai-insert-header">
                  <view class="ai-insert-header-left">
                    <text class="ai-insert-icon">✦</text>
                    <text class="ai-insert-prompt">{{ins.prompt}}</text>
                  </view>
                  <view class="ai-insert-close" bindtap="onRemoveAnalysis" data-index="{{index}}" data-id="{{ins.id}}">×</view>
                </view>
                <text class="ai-insert-result" user-select>{{ins.result}}</text>
              </view>
            </block>

            <!-- 代码块 -->
            <view wx:if="{{item.type === 'code'}}" class="block-code"
              bindlongpress="onParagraphTap"
              data-index="{{index}}" data-text="{{item.text}}">
              <text user-select>{{item.text}}</text>
            </view>

            <!-- 分割线 -->
            <view wx:if="{{item.type === 'divider'}}" class="block-divider"></view>

            <!-- Toggle 折叠块 -->
            <view wx:if="{{item.type === 'toggle'}}" class="block-toggle"
              bindlongpress="onParagraphTap"
              data-index="{{index}}" data-text="{{item.text}}">
              <text>▸ {{item.text}}</text>
            </view>

            <!-- 图片 -->
            <view wx:if="{{item.type === 'img'}}" class="body-image-wrap">
              <view class="body-image-placeholder skeleton-shimmer"></view>
              <image
                src="{{item.src}}"
                mode="widthFix"
                class="body-image"
                lazy-load
              ></image>
            </view>

          </view>
        </block>
      </view>
      
      <view style="height: 120rpx;"></view>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <!-- 收藏（图标按钮，靠左） -->
    <view class="bottom-bookmark-btn" bindtap="toggleBookmark">
      <text class="bottom-bookmark-icon {{bookmarked ? 'bookmarked' : ''}}">{{bookmarked ? '★' : '☆'}}</text>
    </view>

    <!-- 分割线 -->
    <view class="bottom-divider"></view>

    <!-- 状态1：已完成全文分析 → 置灰不可点 -->
    <view wx:if="{{fullAnalyzeDone}}" class="bottom-ai-btn bottom-ai-btn-done">
      <text class="bottom-ai-icon-done">✔</text>
      <text class="bottom-ai-label">已完成全文分析</text>
    </view>

    <!-- 状态2：分析进行中 → 进度动画 + 独立取消按钮 -->
    <block wx:elif="{{isFullAnalyzing}}">
      <view class="bottom-ai-btn bottom-ai-btn-busy">
        <view class="ai-dots">
          <view class="ai-dot"></view>
          <view class="ai-dot"></view>
          <view class="ai-dot"></view>
        </view>
        <text class="bottom-ai-label">分析中 {{fullAnalyzeProgress}}/{{fullAnalyzeTotal}}</text>
      </view>
      <view class="bottom-cancel-btn" bindtap="onCancelFullAnalysis">
        <text class="bottom-cancel-label">取消</text>
      </view>
    </block>

    <!-- 状态3：默认可点击 -->
    <view wx:else class="bottom-ai-btn" bindtap="onFullAnalysis">
      <text class="bottom-ai-icon">✦</text>
      <text class="bottom-ai-label">AI 逐段分析全文</text>
    </view>
  </view>

  <!-- 新手引导：沉浸式动画演示 -->
  <view class="tutorial-overlay" wx:if="{{showTutorial}}" bindtap="onDismissTutorial" catchtouchmove="noop">

    <!-- 右上角关闭按钮（大点击范围） -->
    <view class="tutorial-close-btn-wrap" catchtap="onDismissTutorial">
      <view class="tutorial-close-btn">
        <text class="tutorial-close-icon">×</text>
      </view>
    </view>

    <!-- 中间内容区：模拟文章段落 + 手指动画 -->
    <view class="tutorial-scene" catchtap="noop">

      <!-- 模拟文章标题（不可选） -->
      <text class="tutorial-fake-title">OpenAI 发布全新模型，推理能力大幅提升</text>

      <!-- 模拟段落1（不可选，灰色） -->
      <text class="tutorial-fake-para">当地时间周一，OpenAI 正式宣布推出新一代语言模型，该模型在数学推理、代码生成和多语言理解等方面均有显著进步。</text>

      <!-- 模拟段落2（整个段落被选中并出现高亮） -->
      <view class="tutorial-fake-para" style="position: relative;">
        <view style="display:inline-block; position:relative; z-index:1;">
          <view class="tutorial-selection-bg"></view>
          <text class="tutorial-fake-para-selected">只需长按通过 AI 分析段落内容，即可为您解答。阅读中遇到难以理解的概念和专业术语，它也能提供通俗易懂的解释。</text>
        </view>
        
        <!-- 手指光标 -->
        <view class="tutorial-cursor-wrap">
          <text class="tutorial-cursor">☝️</text>
          <view class="tutorial-press-ring"></view>
          <view class="tutorial-press-ring tutorial-press-ring-2"></view>
        </view>
      </view>

      <!-- 模拟段落3（不可选，灰色） -->
      <text class="tutorial-fake-para">分析人士指出，这一进展将推动 AI 在法律、医疗、教育等垂直领域的更广泛落地应用。</text>
    </view>

    <!-- 模拟 AI 分析面板（从底部滑入） -->
    <view class="tutorial-mock-panel">
      <!-- 拖拽条 -->
      <view class="tutorial-drag-bar-wrap">
        <view class="tutorial-drag-bar"></view>
      </view>
      <!-- 标题行 -->
      <view class="tutorial-mock-header">
        <view class="tutorial-mock-title-row">
          <text class="tutorial-mock-icon">✦</text>
          <text class="tutorial-mock-title">AI 分析</text>
        </view>
        <view class="tutorial-mock-close" bindtap="onDismissTutorial">
          <text class="tutorial-mock-close-icon">×</text>
        </view>
      </view>
      <!-- 选中内容框 -->
      <view class="tutorial-mock-selected-box">
        <text class="tutorial-mock-selected-label">选中内容</text>
        <text class="tutorial-mock-selected-text">只需长按通过 AI 分析段落内容，即可为您…</text>
      </view>
      <!-- 快捷操作 -->
      <view class="tutorial-mock-chips">
        <view class="tutorial-chip">翻译中文</view>
        <view class="tutorial-chip">解释一下</view>
        <view class="tutorial-chip">分析</view>
        <view class="tutorial-chip">背景知识</view>
      </view>
      <!-- 输入行 -->
      <view class="tutorial-mock-input-row">
        <view class="tutorial-mock-input">
          <text class="tutorial-mock-input-text">翻译为中文，列出重点词汇…</text>
        </view>
        <view class="tutorial-mock-send">
          <text class="tutorial-mock-send-text">发送</text>
        </view>
      </view>
      <!-- 底部提示 -->
      <view class="tutorial-hint-row">
        <text class="tutorial-hint-text">点击任意位置关闭引导</text>
      </view>
    </view>

  </view>


  <!-- 遮罩层 -->
  <view class="ai-overlay" wx:if="{{showAiPanel}}" bindtap="closeAiPanel" catchtouchmove="noop"></view>

  <!-- AI 分析底部弹窗（无拖拽，固定高度，键盘感知） -->
  <view
    class="ai-panel {{showAiPanel ? 'ai-panel-show' : ''}}"
    style="bottom: {{keyboardHeight > 0 ? keyboardHeight + 'px' : '0px'}}"
  >
    <!-- 顶部装饰条（不可拖拽） -->
    <view class="ai-top-bar">
      <view class="ai-drag-bar"></view>
    </view>

    <!-- 标题行 -->
    <view class="ai-panel-header">
      <view class="ai-panel-title-wrap">
        <text class="ai-panel-icon">✦</text>
        <text class="ai-panel-title">AI 分析</text>
      </view>
      <view class="ai-panel-close" bindtap="closeAiPanel">
        <text class="ai-close-icon">×</text>
      </view>
    </view>

    <!-- 选中内容（可滚动、可编辑） -->
    <view class="ai-selected-box">
      <view class="ai-selected-label-row">
        <text class="ai-selected-label">选中内容</text>
        <!-- 朗读选中的英文句子 -->
        <view
          class="ai-panel-speak-btn {{isSpeaking ? 'speaking' : ''}}"
          bindtap="onSpeakSelected"
        >
          <view class="ai-panel-speak-icon"></view>
        </view>
      </view>
      <scroll-view scroll-y class="ai-selected-scroll" enhanced show-scrollbar="{{false}}">
        <textarea
          class="ai-selected-input"
          value="{{selectedText}}"
          bindinput="onSelectedTextChange"
          maxlength="-1"
          fixed
          adjust-position="{{false}}"
          hold-keyboard="{{true}}"
          cursor-spacing="100"
          show-confirm-bar="{{false}}"
        ></textarea>
      </scroll-view>
    </view>

    <!-- 快捷操作按钮 -->
    <scroll-view scroll-x class="ai-quick-scroll" enhanced show-scrollbar="{{false}}">
      <view class="ai-quick-btns">
        <view class="ai-quick-btn" bindtap="onQuickAction" data-action="翻译中文">翻译中文</view>
        <view class="ai-quick-btn" bindtap="onQuickAction" data-action="解释一下">解释一下</view>
        <view class="ai-quick-btn" bindtap="onQuickAction" data-action="分析">分析</view>
        <view class="ai-quick-btn" bindtap="onQuickAction" data-action="背景知识">背景知识</view>
        <view class="ai-quick-btn" bindtap="onQuickAction" data-action="客观评价">客观评价</view>
      </view>
    </scroll-view>

    <!-- 输入行 (统一用 textarea 以保证切换时不收起键盘) -->
    <view class="ai-input-row">
      <textarea
        class="ai-input"
        placeholder="{{aiInput ? '' : '翻译为中文，输出原文，列出重点单词和词组，简短'}}"
        placeholder-class="ai-input-placeholder"
        bindinput="onAiInputChange"
        value="{{aiInput}}"
        confirm-type="send"
        bindconfirm="onSendAi"
        disabled="{{isAnalyzing}}"
        adjust-position="{{false}}"
        hold-keyboard="{{true}}"
        auto-height
        fixed
        cursor-spacing="20"
        show-confirm-bar="{{false}}"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
      ></textarea>
      <view class="ai-send-btn {{isAnalyzing ? 'ai-send-btn-analyzing' : ''}}" bindtap="{{isAnalyzing ? '' : 'onSendAi'}}">
        <block wx:if="{{isAnalyzing}}">
          <view class="ai-dots">
            <view class="ai-dot"></view>
            <view class="ai-dot"></view>
            <view class="ai-dot"></view>
          </view>
        </block>
        <text class="ai-send-text" wx:else>发送</text>
      </view>
    </view>
  </view>

  <!-- 单词翻译气泡 -->
  <view 
    class="word-bubble-overlay" 
    wx:if="{{showWordBubble}}" 
    bindtap="closeWordBubble" 
    catchtouchmove="noop"
  ></view>
  
  <view 
    class="word-bubble" 
    wx:if="{{showWordBubble}}"
    style="top: {{bubbleTop}}px; left: {{bubbleLeft}}px;"
    catchtap="noop"
  >
    <!-- 箭头 -->
    <view class="word-bubble-arrow {{bubbleArrowUp ? 'word-bubble-arrow-up' : 'word-bubble-arrow-down'}}"></view>

    <!-- 加载中 -->
    <view wx:if="{{isBubbleLoading}}" class="ai-dots" style="padding: 60rpx 0;">
      <view class="ai-dot" style="background-color: #8B5CF6"></view>
      <view class="ai-dot" style="background-color: #8B5CF6"></view>
      <view class="ai-dot" style="background-color: #8B5CF6"></view>
    </view>

    <!-- 内容展示 -->
    <block wx:else>
      <view class="bubble-word-row">
        <view class="bubble-word-left">
          <text class="bubble-word">{{bubbleData.word}}</text>
          <text class="bubble-phonetic">{{bubbleData.phonetic}}</text>
          <text class="bubble-pos">{{bubbleData.pos}}</text>
        </view>
        <view class="bubble-speak-btn" catchtap="onSpeakWord">
          <view class="bubble-speak-btn-icon"></view>
        </view>
      </view>
      
      <view class="bubble-trans-group">
        <view class="bubble-trans-item">
          <text class="bubble-trans-label">语境义</text>
          <text class="bubble-trans-val">{{bubbleData.trans_context}}</text>
        </view>
        <view class="bubble-trans-item" wx:if="{{bubbleData.trans_general && bubbleData.trans_general !== bubbleData.trans_context}}">
          <text class="bubble-trans-label">字典义</text>
          <text class="bubble-trans-val">{{bubbleData.trans_general}}</text>
        </view>
      </view>
      
      <!-- 句子翻译 -->
      <view class="bubble-context-trans" wx:if="{{bubbleData.sentence_trans}}">
        <text class="bubble-sentence-trans-text">“{{bubbleData.sentence_trans}}”</text>
      </view>

      <view class="bubble-btns">
        <view 
          class="bubble-btn-add {{isExistedInVocab ? 'bubble-btn-add-done' : ''}}" 
          catchtap="onAddToVocab"
        >
          {{isExistedInVocab ? '已加入 ✓' : '+ 加入生词本'}}
        </view>
      </view>
    </block>
  </view>

</view>