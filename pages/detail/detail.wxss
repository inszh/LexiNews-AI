.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  overflow: hidden;
}

.detail-scroll {
  flex: 1;
  height: 0;
}

/* 核心：图片容器。去掉了顶部的 margin，实现贴顶 */
.hero-image-wrap {
  position: relative;
  width: 94%; /* 稍微加宽一点 */
  margin: 20rpx auto 0; /* 仅保留 20rpx 的极小呼吸感，如果想完全贴死就改 0 */
  height: 500rpx;
  border-radius: 40rpx;
  overflow: hidden;
  transform: translateY(0);
  background-color: #f5f5f5;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-cat-badge {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  backdrop-filter: blur(10px);
}

.article-body {
  padding: 40rpx 40rpx 150rpx;
}

.article-title-wrap {
  width: 100%;
  display: block;
}

.article-title {
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 40rpx;
  color: #000;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 50rpx;
}

.ai-insert-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.ai-insert-header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.ai-insert-close {
  color: #C8C4BF;
  font-size: 34rpx;
  line-height: 1;
  padding: 0 10rpx;
  margin-left: 20rpx;
}

.ai-insert-close:active {
  color: #2b2b2b;
}

.author-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.author-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.meta-time {
  font-size: 24rpx;
  color: #999;
}

.meta-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.meta-readtime {
  font-size: 22rpx;
  color: #bbb;
  margin-left: auto;
  align-self: center;
  flex-shrink: 0;
}

.summary-box {
  background: #f8f8f8;
  padding: 36rpx;
  border-radius: 24rpx;
  margin-bottom: 50rpx;
}

/* AI 提示横幅 */
.ai-hint-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #1a1a1a;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 40rpx;
  gap: 18rpx;
}

.ai-hint-icon {
  font-size: 28rpx;
  color: #f0b429;
  flex-shrink: 0;
  line-height: 1;
}

.ai-hint-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
  flex: 1;
}

.summary-label {
  font-size: 20rpx;
  color: #bbb;
  display: block;
  margin-bottom: 12rpx;
}

.summary-text {
  font-size: 30rpx;
  color: #444;
  line-height: 1.6;
}

.paragraph {
  font-size: 34rpx;
  line-height: 1.75;
  color: #1a1a1a;
  margin-bottom: 32rpx;
  text-align: left;
  letter-spacing: 0;
  word-spacing: 0;
}

/* 图片占位符包裹层 */
.body-image-wrap {
  width: 100%;
  min-height: 240rpx;
  background: #f0f0f0;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 20rpx 0 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.body-image-placeholder {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 60rpx;
  opacity: 0.3;
}

.body-image {
  width: 100%;
  display: block;
  position: relative;
  z-index: 1;
}

/* 段落选中状态 */
.paragraph-selected {
  background: #fff9e6;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-left: -16rpx;
  margin-right: -16rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(26,26,24,0.07);
  padding: 12rpx 0;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.bookmark-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 40rpx;
  border-radius: 40rpx;
  background: #F5F3EF;
  transition: transform 0.15s;
}
.bookmark-btn:active { transform: scale(0.94); }

.bookmark-star {
  font-size: 36rpx;
  color: #C8C4BF;
  line-height: 1;
  transition: color 0.2s;
}
.bookmark-star.bookmarked { color: #F0B429; }

.bookmark-label {
  font-size: 26rpx;
  color: #6A6660;
  font-weight: 600;
}

/* ===== 新增块类型样式 ===== */

.block-h1 {
  font-size: 44rpx;
  font-weight: 800;
  color: #111;
  line-height: 1.4;
  margin: 50rpx 0 24rpx;
}

.block-h2 {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
  margin: 44rpx 0 20rpx;
}

.block-h3 {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin: 36rpx 0 16rpx;
}

.block-bullet {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.bullet-dot {
  font-size: 34rpx;
  color: #888;
  margin-right: 16rpx;
  line-height: 1.8;
  flex-shrink: 0;
}

.bullet-text {
  font-size: 34rpx;
  color: #2c2c2c;
  line-height: 1.8;
  flex: 1;
  letter-spacing: 0.3px;
  word-spacing: 1px;
}

.block-quote {
  border-left: 8rpx solid #e0e0e0;
  padding: 20rpx 28rpx;
  margin: 30rpx 0;
  font-size: 32rpx;
  color: #666;
  line-height: 1.8;
  font-style: italic;
  background: #fafafa;
  border-radius: 0 16rpx 16rpx 0;
  letter-spacing: 0.3px;
  word-spacing: 1px;
}

.block-callout {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  background: #f4f4f4;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 30rpx 0;
  gap: 20rpx;
}

.callout-emoji {
  font-size: 36rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

.callout-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  flex: 1;
  letter-spacing: 0.3px;
  word-spacing: 1px;
}

.block-code {
  background: #1e1e1e;
  color: #d4d4d4;
  font-size: 26rpx;
  line-height: 1.8;
  padding: 28rpx;
  border-radius: 16rpx;
  margin: 24rpx 0;
  overflow-x: auto;
}

.block-divider {
  height: 1rpx;
  background: #e8e8e8;
  margin: 40rpx 0;
}

.block-toggle {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 0 12rpx;
}

.loading-state {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 60rpx 0;
}

/* ===== 骨架屏 ===== */

@keyframes skeleton-pulse {
  0%   { background-color: #ebebeb; }
  50%  { background-color: #d4d4d4; }
  100% { background-color: #ebebeb; }
}

/* 通用骨架闪动 */
.skeleton-shimmer {
  animation: skeleton-pulse 1.6s ease-in-out infinite;
  background-color: #ebebeb;
}

.skeleton-wrap {
  padding-top: 8rpx;
}

/* 文字行 */
.skeleton-line {
  height: 28rpx;
  border-radius: 8rpx;
  margin-bottom: 18rpx;
  animation: skeleton-pulse 1.6s ease-in-out infinite;
  background-color: #ebebeb;
}

.skeleton-line-full  { width: 100%; }
.skeleton-line-3q    { width: 75%; }
.skeleton-line-half  { width: 50%; }

/* 段落间距 */
.skeleton-gap {
  height: 36rpx;
}

/* 图片占位块 */
.skeleton-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
  animation: skeleton-pulse 1.6s ease-in-out infinite;
  background-color: #ebebeb;
}

/* ===== AI 分析面板 ===== */

/* 半透明遗罩 */
.ai-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

/* 底部面板 */
.ai-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 36rpx 40rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.32s cubic-bezier(0.34, 1.02, 0.64, 1),
              bottom 0.25s ease-out;
  display: flex;
  flex-direction: column;
  height: 52vh;
  overflow: hidden;
}

.ai-panel-show {
  transform: translateY(0);
}

/* 顶部装饰条（纯视觉，不可拖拽） */
.ai-top-bar {
  padding: 12rpx 0 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

/* 装饰条 */
.ai-drag-bar {
  width: 72rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

/* 标题行 */
.ai-panel-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.ai-panel-title-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}

.ai-panel-icon {
  font-size: 30rpx;
  color: #1a1a1a;
}

.ai-panel-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.ai-panel-close {
  width: 72rpx;
  height: 72rpx;
  background: #f2f2f2;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-close-icon {
  font-size: 40rpx;
  color: #666;
  line-height: 1;
}

/* 选中内容框 */
.ai-selected-box {
  background: #f5f5f3;
  border-radius: 20rpx;
  padding: 4rpx 24rpx 12rpx;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.ai-selected-label {
  font-size: 20rpx;
  color: #aaa;
  display: block;
}

/* 可滚动区域 */
.ai-selected-scroll {
  max-height: 200rpx;
}

/* 可编辑 textarea */
.ai-selected-input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  background: transparent;
  min-height: 60rpx;
}

/* 快捷按鈕行 */
.ai-quick-scroll {
  width: 100%;
  margin-bottom: 28rpx;
}

.ai-quick-btns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  white-space: nowrap;
  padding-bottom: 4rpx;
}

.ai-quick-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  white-space: nowrap;
  flex-shrink: 0;
  background: #fff;
}

.ai-quick-btn:active {
  background: #f5f5f5;
}

/* 输入行 */
.ai-input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.ai-input {
  flex: 1;
  height: 96rpx;
  background: #f5f5f3;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.ai-input-placeholder {
  color: #bbb;
}

.ai-send-btn {
  width: 140rpx;
  height: 96rpx;
  background: #1a1a1a;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-send-btn:active {
  opacity: 0.8;
}

.ai-send-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.ai-send-btn-analyzing {
  pointer-events: none;
  background: linear-gradient(90deg, #2b2b2b, #666, #2b2b2b);
  background-size: 200% 100%;
  animation: ai-bg-shift 2s infinite linear;
}

@keyframes ai-bg-shift {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.ai-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.ai-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #ffffff;
  border-radius: 50%;
  animation: ai-bounce 1.4s infinite ease-in-out both;
}

.ai-dot:nth-child(1) { animation-delay: -0.32s; }
.ai-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes ai-bounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* ===== AI 结果内嵌卡片 ===== */
.ai-insert-card {
  background: #f7f7f5;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #1a1a1a;
}

.ai-insert-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.ai-insert-icon {
  font-size: 22rpx;
  color: #1a1a1a;
  flex-shrink: 0;
}

.ai-insert-prompt {
  font-size: 24rpx;
  font-weight: 600;
  color: #555;
}

.ai-insert-result {
  font-size: 30rpx;
  color: #222;
  line-height: 1.8;
  display: block;
}

/* ===== TTS 朗读按钮（在 AI 面板的选中内容标题行） ===== */
.ai-selected-label-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0rpx;
}

.ai-panel-speak-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}

.ai-panel-speak-btn.speaking {
  background: #1a1a1a;
}

.ai-panel-speak-icon {
  font-size: 26rpx;
  line-height: 1;
}